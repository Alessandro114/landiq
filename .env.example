# LandIQ — environment variables
# Copy to .env and fill in your values

# AI Provider — the agent uses one of these for the executive verdict.
# All have generous free tiers (1,000+ reports/day at zero cost).
# Set at least ONE. The agent tries them in order: Groq → Cerebras → Mistral.

# Option 1: Groq (recommended — free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Cerebras (free at https://cloud.cerebras.ai)
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# Option 3: Mistral (free at https://console.mistral.ai)
# MISTRAL_API_KEY=your_mistral_api_key_here

# Option 4: OpenAI (paid — https://platform.openai.com)
# OPENAI_API_KEY=your_openai_api_key_here

# Advanced: override provider and model explicitly
# LANDIQ_AI_PROVIDER=groq
# LANDIQ_AI_MODEL=llama-3.3-70b-versatile

# Optional: cache directory for scraped data (default: ./data/cache)
LANDIQ_CACHE_DIR=./data/cache
