# LandIQ — environment variables
# Copy to .env and fill in your values

# ─── AI Provider (bring your own key) ────────────────────────
#
# The agent needs ONE API key for the AI verdict. Pick any provider you like.
# All of them have free tiers. No vendor lock-in — switch anytime.
#
# Set ONE of these (whichever you prefer):

GROQ_API_KEY=            # https://console.groq.com (free, fast)
# CEREBRAS_API_KEY=      # https://cloud.cerebras.ai (free)
# MISTRAL_API_KEY=       # https://console.mistral.ai (free)
# OPENAI_API_KEY=        # https://platform.openai.com (paid)

# Or run fully local with Ollama (zero cloud, zero API key):
# LANDIQ_AI_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434

# Advanced: force a specific provider + model
# LANDIQ_AI_PROVIDER=groq
# LANDIQ_AI_MODEL=llama-3.3-70b-versatile

# ─── General ─────────────────────────────────────────────────

# Cache directory for scraped data (default: ./data/cache)
LANDIQ_CACHE_DIR=./data/cache
